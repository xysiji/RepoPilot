REPOPILOT_APP_NAME=RepoPilot
REPOPILOT_APP_ENV=development
REPOPILOT_LOG_LEVEL=INFO
REPOPILOT_WORKSPACE_PATH=demo_workspace
REPOPILOT_MODEL_PROVIDER=openai
REPOPILOT_MODEL_NAME=gpt-4.1-mini
REPOPILOT_MODEL_API_KEY=replace-with-provider-api-key
REPOPILOT_MODEL_BASE_URL=https://api.openai.com/v1
REPOPILOT_MODEL_TEMPERATURE=0.0
REPOPILOT_MODEL_TIMEOUT_SECONDS=30.0
REPOPILOT_PYTEST_TARGET=tests
REPOPILOT_PYTEST_TIMEOUT_SECONDS=60.0
REPOPILOT_PYTEST_MAX_OUTPUT_CHARACTERS=20000
REPOPILOT_MAX_REPAIR_ATTEMPTS=3
REPOPILOT_DATA_DIRECTORY=.repopilot
REPOPILOT_CHECKPOINT_DATABASE_NAME=checkpoints.sqlite3
REPOPILOT_RUNTIME_DATABASE_NAME=runtime.sqlite3
REPOPILOT_RUN_RETENTION_DAYS=30
REPOPILOT_TRACE_RETENTION_DAYS=30
REPOPILOT_MAX_TRACE_EVENTS_PER_RUN=500
REPOPILOT_MODEL_CONTEXT_MAX_CHARACTERS=60000
REPOPILOT_MODEL_CONTEXT_RECENT_BLOCKS=8
REPOPILOT_MODEL_CONTEXT_TOOL_RESULT_MAX_CHARACTERS=4000
REPOPILOT_MODEL_CONTEXT_SUMMARY_MAX_CHARACTERS=2000
